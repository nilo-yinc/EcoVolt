# Render backend environment template
# Copy these key/values into Render -> Service -> Environment

# Keep API stable in cloud (no webcam/GPU)
RUN_VISION=0

# Render provides PORT automatically. Keep this fallback only if needed.
PORT=8000

# Optional, default host already used in run.py
HOST=0.0.0.0

# Optional metadata key used by CV pipeline
CV_ROOM_ID=test-room

# Keep disabled in cloud
CV_SHOW_WINDOW=0
